// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id              String    @id @default(uuid())
  nameFirst       String?
  nameMiddle      String?
  nameLast        String?
  nameDisplay     String?
  displayName     String?
  accountPhoto    String?
  gender          String?
  dateBirth       DateTime?
  dateCreated     DateTime  @default(now())
  nationality     String?
  isLegalEntity   Boolean   @default(false)
  nameLegal       String?
  registrationId  String?
  countryOfOrigin String?
  dateEstablished DateTime?
  neupIdPrimary   String?
  verified        Boolean   @default(false)
  pro             Boolean   @default(false)
  accountType     String    @default("individual")
  permit          String    @default("default") // default, addition, reduction, addition_reduction
  accountStatus   String?
  parentBrandId   String?
  parentBrand     Account?  @relation("BrandBranches", fields: [parentBrandId], references: [id])
  branches        Account[] @relation("BrandBranches")
  
  // JSON fields for unstructured data like 'block'
  block           Json?

  // Relations
  contacts        Contact[]
  neupIds         NeupId[]
  permits         Permit[]
  targetPermits   Permit[] @relation("TargetAccount")
  password        Password?
  sessions        Session[]
  errorLogs       ErrorLog[]
  statusLogs      AccountStatusLog[]
  appConnections  UserAppConnection[]
  appAuthentications AppAuthentication[]
  appSessions     AppSession[]
  externalSessions AuthSessionExternal[]
  externalRoles   AuthRoleExternal[]
  externalPermissions AuthPermissionsExternal[]
  kycRequests     KycRequest[]
  invitations     Invitation[]   @relation("Inviter")
  neupIdRequests  NeupIdRequest[]
  notifications   Notification[]
  backupCodes     BackupCode[]
  verifications   Verification[]
  documents       UserDocument[]
  userContents    UserContent[]
  totp            Totp?
  sentRequests    Request[] @relation("SentRequests")
  receivedRequests Request[] @relation("ReceivedRequests")

  // New Auth Team & Permission Relations
  adminTeams        AuthTeam[] @relation("AccountAsAdmin")
  memberTeams       AuthTeam[] @relation("AccountAsTeamMember")
  externalAdminTeams AuthTeamExternal[] @relation("AccountAsExternalAdmin")
  externalMemberTeams AuthTeamExternal[] @relation("AccountAsExternalTeamMember")
  authRolesInternal AuthRole[]
  recipientPermissions AuthPermissionRecipient[] @relation("RecipientPermissions")
  ownerPermissions   AuthPermissionRecipient[] @relation("OwnerPermissions")

  @@map("accounts")
}

model Totp {
  accountId String   @id
  secret    String
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id])

  @@map("auth_totp")
}

model SystemConfig {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model AuthRequest {
  id        String   @id @default(uuid())
  type      String
  status    String   @default("pending")
  data      Json     @default("{}")
  accountId String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("auth_requests")
}

model ActivityLog {
  id              String   @id @default(uuid())
  targetAccountId String
  actorAccountId  String
  action          String
  status          String
  ip              String
  timestamp       DateTime @default(now())
  geolocation     String?

  @@map("activity_logs")
}

model AccountStatusLog {
  id        String   @id @default(uuid())
  accountId String
  status    String
  remarks   String?
  fromDate  DateTime @default(now())
  moreInfo  String?

  account   Account  @relation(fields: [accountId], references: [id])

  @@map("account_status_logs")
}

model KycRequest {
  id                     String   @id @default(uuid())
  accountId              String
  documentType           String
  documentId             String?
  documentPhotoUrl       String?
  documentPhotoContentId String?
  selfiePhotoUrl         String?
  selfiePhotoContentId   String?
  status                 String   @default("pending") // 'pending' | 'approved' | 'rejected'
  rejectionReason        String?
  submittedAt            DateTime @default(now())
  userFullName           String?
  userNeupId             String?

  account                Account  @relation(fields: [accountId], references: [id])

  @@map("kyc_requests")
}

model Invitation {
  id              String   @id @default(uuid())
  inviterAccountId String
  inviteeEmail    String
  role            String   @default("member")
  status          String   @default("pending") // 'pending' | 'accepted' | 'declined' | 'expired'
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  inviter         Account  @relation("Inviter", fields: [inviterAccountId], references: [id])

  @@map("invitations")
}

model NeupIdRequest {
  id          String   @id @default(uuid())
  accountId   String
  requestedId String   @unique
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  reason      String?
  submittedAt DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id])

  @@map("neupid_requests")
}

model Notification {
  id          String    @id @default(uuid())
  accountId   String
  action      String?
  title       String?
  message     String?
  type        String    @default("info") // 'info' | 'success' | 'warning' | 'error'
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  deletableOn DateTime?
  persistence String?   // 'dismissable' | 'untildays' | 'permanent'
  requestId   String?

  account     Account   @relation(fields: [accountId], references: [id])
  request     Request?  @relation(fields: [requestId], references: [id])

  @@map("notifications")
}

model Request {
  id              String   @id @default(uuid())
  senderId        String
  recipientId     String
  status          String   @default("pending") // 'pending' | 'approved' | 'rejected'
  action          String   // 'family_invitation' | 'access_invitation' | 'display_name_request'
  type            String?  // 'partner' | 'dependent' | 'other'
  data            Json?    @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sender          Account  @relation("SentRequests", fields: [senderId], references: [id])
  recipient       Account  @relation("ReceivedRequests", fields: [recipientId], references: [id])
  notifications   Notification[]

  @@map("requests")
}

model Family {
  id              String   @id @default(uuid())
  createdBy       String
  memberIds       String[]
  members         Json     // Array of { accountId: string, addedOn: DateTime, addedBy: string, hidden: boolean, status: string }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("families")
}

model BackupCode {
  id          String   @id @default(uuid())
  accountId   String
  code        String
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id])

  @@map("backup_codes")
}

model Verification {
  id               String    @id @default(uuid())
  accountId        String
  type             String    // 'email' | 'phone' | 'identity' | 'account'
  token            String?
  code             String?
  status           String    @default("pending") // 'pending' | 'verified' | 'expired' | 'approved' | 'revoked'
  reason           String?
  category         String?
  verifiedBy       String?
  revokedBy        String?
  revocationReason String?
  createdAt        DateTime  @default(now())
  verifiedAt       DateTime?
  revokedAt        DateTime?

  account          Account   @relation(fields: [accountId], references: [id])

  @@map("verifications")
}

model UserDocument {
  id          String   @id @default(uuid())
  accountId   String
  type        String   // 'id_card' | 'passport' | 'utility_bill' | 'other'
  url         String
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  uploadedAt  DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id])

  @@map("user_documents")
}

model Contact {
  id          String  @id @default(uuid())
  accountId   String
  contactType String
  value       String
  
  account     Account @relation(fields: [accountId], references: [id])

  @@map("contacts")
}

model NeupId {
  id        String  @id // The neupId string itself
  accountId String
  isPrimary Boolean @default(false)
  
  account   Account @relation(fields: [accountId], references: [id])

  @@map("neup_ids")
}

model Password {
  accountId           String   @id
  hash                String
  passwordLastChanged DateTime @default(now())
  
  account             Account  @relation(fields: [accountId], references: [id])

  @@map("passwords")
}

model Permit {
  id                String   @id @default(uuid())
  permitType        String?  // e.g. "property", "vehicle", "business"
  permitSubType     String?  // e.g. "residential", "commercial"
  permitNumber      String?
  issuingAuthority  String?
  issueDate         DateTime?
  expiryDate        DateTime?
  status            String    @default("active") // active, expired, revoked
  accountId         String
  targetAccountId   String?
  forSelf           Boolean   @default(false)
  isRoot            Boolean   @default(false)
  fullAccess        Boolean   @default(false)
  permissions       String[]
  restrictions      String[]
  createdOn         DateTime  @default(now())
  managedBy         String?
  
  account           Account @relation(fields: [accountId], references: [id])
  targetAccount     Account? @relation("TargetAccount", fields: [targetAccountId], references: [id])

  @@map("permits")
}

model Session {
  id          String   @id @default(uuid())
  accountId   String
  ipAddress   String
  userAgent   String
  lastLoggedIn DateTime
  loginType     String
  geolocation String?
  deviceType  String?   // 'android' | 'ios' | 'web' | etc.
  expiresOn       DateTime?
  isExpired       Boolean   @default(false)
  authSessionKey  String?
  dependentKeys   Json?
  
  appSessions     AppSession[]
  account     Account  @relation(fields: [accountId], references: [id])

  @@map("sessions")
}

// New models for error tracking and bug reports
model ErrorLog {
  id          String    @id @default(uuid())
  type        String    // 'ai' | 'database' | 'validation' | 'auth' | 'unknown'
  context     String
  message     String
  status      String    @default("new") // 'new' | 'in_progress' | 'solved'
  accountId   String?
  ipAddress   String?
  geolocation String?
  reproSteps  String?
  solution    String?
  solvedBy    String?
  problemLevel String?   // 'hot' | 'warm' | 'cold'
  timestamp   DateTime  @default(now())
  
  account     Account?  @relation(fields: [accountId], references: [id])

  @@map("error_logs")
}

model BugReport {
  id          String    @id @default(uuid())
  reportType  String    @default("submitted")
  context     String    // title
  message     String    // description
  status      String    @default("new") // 'new' | 'in_progress' | 'solved'
  reportedBy  String?
  timestamp   DateTime  @default(now())
  
  @@map("bug_reports")
}

model UserContent {
  id           String   @id @default(uuid())
  contentId    String?
  uploaderId   String?
  forAccountId String
  platform     String
  url          String
  originalName String?
  fileType     String?
  size         Int?
  uploadedAt   DateTime @default(now())
  contentType  String? // 'profile_photo' | 'document' | 'other'

  account Account @relation(fields: [forAccountId], references: [id])

  @@map("user_content")
}

model RecoveryContact {
  id               String   @id @default(uuid())
  ownerAccountId   String
  recoveryAccountId String
  recoveryNeupId   String
  status           String   @default("pending") // 'pending' | 'approved' | 'rejected'
  createdAt        DateTime @default(now())

  @@map("recovery_contacts")
}

model Application {
  id          String   @id
  name        String
  party       String   @default("third") // 'first' | 'third'
  description String?
  icon        String?
  website     String?
  developer   String?
  appSecret   String?
  createdAt   DateTime @default(now())

  connections UserAppConnection[]
  appAuthentications AppAuthentication[]
  appSessions     AppSession[]
  externalSessions AuthSessionExternal[]
  externalRoles   AuthRoleExternal[]
  externalPermissions AuthPermissionsExternal[]
  
  // New Auth Team & Permission Models
  authTeams           AuthTeam[]
  authTeamsExternal   AuthTeamExternal[]
  authRoles           AuthRole[]
  authPermissionRecipients AuthPermissionRecipient[]

  @@map("applications")
}

model AuthTeam {
  id           String   @id @default(uuid())
  appId        String
  accountId    String   // Admin/Manager account
  recipientId  String   // User being added
  isPermanent  Boolean  @default(false)
  createdAt    DateTime @default(now())

  application  Application @relation(fields: [appId], references: [id])
  account      Account     @relation("AccountAsAdmin", fields: [accountId], references: [id])
  recipient    Account     @relation("AccountAsTeamMember", fields: [recipientId], references: [id])

  @@unique([appId, accountId, recipientId])
  @@map("auth_teams")
}

model AuthTeamExternal {
  id           String   @id @default(uuid())
  appId        String
  accountId    String   // Admin/Manager account
  recipientId  String   // User being added
  isPermanent  Boolean  @default(false)
  createdAt    DateTime @default(now())

  application  Application @relation(fields: [appId], references: [id])
  account      Account     @relation("AccountAsExternalAdmin", fields: [accountId], references: [id])
  recipient    Account     @relation("AccountAsExternalTeamMember", fields: [recipientId], references: [id])

  @@unique([appId, accountId, recipientId])
  @@map("auth_teams_external")
}

model AuthRole {
  id           String   @id @default(uuid())
  appId        String
  accountId    String
  role         String
  isPermanent  Boolean  @default(false)
  createdAt    DateTime @default(now())

  application  Application @relation(fields: [appId], references: [id])
  account      Account     @relation(fields: [accountId], references: [id])

  @@unique([appId, accountId])
  @@map("auth_roles")
}

model AuthPermissionRecipient {
  id           String   @id @default(uuid())
  appId        String
  recipientId  String
  ownerId      String
  assetId      String?  // Optional asset identifier
  permission   String
  isPermanent  Boolean  @default(true)
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  application  Application @relation(fields: [appId], references: [id])
  recipient    Account     @relation("RecipientPermissions", fields: [recipientId], references: [id])
  owner        Account     @relation("OwnerPermissions", fields: [ownerId], references: [id])

  @@map("auth_permission_recipients")
}

model UserAppConnection {
  id        String   @id @default(uuid())
  accountId String
  appId     String
  connectedAt DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("user_app_connections")
}

model AppAuthentication {
  id          String   @id @default(uuid())
  appId       String
  accountId   String
  permissions Json?    @default("[]")
  createdAt   DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([appId, accountId])
  @@map("app_authentications")
}

model AppSession {
  id           String   @id @default(uuid())
  accountId    String
  sessionId    String   // Link to NeupAccount session
  appId        String
  sessionValue String   @unique // The specific session token for the app
  createdOn    DateTime @default(now())
  activeTill   DateTime

  account      Account     @relation(fields: [accountId], references: [id])
  application  Application @relation(fields: [appId], references: [id])
  session      Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("app_sessions")
}

model AuthSessionExternal {
  id           String   @id @default(uuid())
  accountId    String
  appId        String
  sessionId    String
  sessionKey   String
  jwt          String   @db.Text
  expiresOn    DateTime
  createdAt    DateTime @default(now())

  account      Account     @relation(fields: [accountId], references: [id])
  application  Application @relation(fields: [appId], references: [id])

  @@map("auth_sessions_external")
}

model AuthRoleExternal {
  id        String   @id @default(uuid())
  accountId String
  appId     String
  role      String
  hasExtra  Boolean  @default(false)
  createdAt DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("auth_roles_external")
}

model AuthPermissionsExternal {
  id          String   @id @default(uuid())
  accountId   String
  appId       String
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("auth_permissions_external")
}
