// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id              String    @id @default(uuid())
  nameFirst       String?
  nameMiddle      String?
  nameLast        String?
  nameDisplay     String?
  displayName     String?
  accountPhoto    String?
  gender          String?
  dateBirth       DateTime?
  dateCreated     DateTime  @default(now())
  nationality     String?
  isLegalEntity   Boolean   @default(false)
  nameLegal       String?
  registrationId  String?
  countryOfOrigin String?
  dateEstablished DateTime?
  neupIdPrimary   String?
  verified        Boolean   @default(false)
  pro             Boolean   @default(false)
  accountType     String    @default("individual")
  permit          String    @default("default") // default, addition, reduction, addition_reduction
  accountStatus   String?
  parentBrandId   String?
  parentBrand     Account?  @relation("BrandBranches", fields: [parentBrandId], references: [id])
  branches        Account[] @relation("BrandBranches")

  // JSON fields for unstructured data like 'block'
  block Json?

  // Relations
  contacts            Contact[]
  neupIds             NeupId[]
  permits             Permit[]
  targetPermits       Permit[]                  @relation("TargetAccount")
  password            Password?
  sessions            Session[]
  errorLogs           ErrorLog[]
  appConnections      UserAppConnection[]
  appAuthentications  AppAuthentication[]
  appSessions         AppSession[]
  externalSessions    AuthSessionExternal[]
  externalRoles       AuthRoleExternal[]
  externalPermissions AuthPermissionsExternal[]
  ownedApplications   Application[]
  notifications       Notification[]
  backupCodes         BackupCode[]
  verifications       Verification[]
  totp                Totp?
  sentRequests        Request[]                 @relation("SentRequests")
  receivedRequests    Request[]                 @relation("ReceivedRequests")

  // New Auth Team & Permission Relations
  adminTeams           AuthTeam[]                @relation("AccountAsAdmin")
  memberTeams          AuthTeam[]                @relation("AccountAsTeamMember")
  externalAdminTeams   AuthTeamExternal[]        @relation("AccountAsExternalAdmin")
  externalMemberTeams  AuthTeamExternal[]        @relation("AccountAsExternalTeamMember")
  authRolesInternal    AuthRole[]
  recipientPermissions AuthPermissionRecipient[] @relation("RecipientPermissions")
  ownerPermissions     AuthPermissionRecipient[] @relation("OwnerPermissions")

  @@map("accounts")
}

model Totp {
  accountId String   @id
  secret    String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@map("auth_totp")
}

model AppProfile {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("app_profiles")
}

model AuthRequest {
  id        String   @id @default(uuid())
  type      String
  status    String   @default("pending")
  data      Json     @default("{}")
  accountId String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("auth_requests")
}

model ActivityLog {
  id              String   @id @default(uuid())
  targetAccountId String
  actorAccountId  String
  action          String
  status          String
  ip              String
  timestamp       DateTime @default(now())
  geolocation     String?

  @@map("activity")
}

model Notification {
  id          String    @id @default(uuid())
  accountId   String
  action      String?
  title       String?
  message     String?
  type        String    @default("info") // 'info' | 'success' | 'warning' | 'error'
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  deletableOn DateTime?
  persistence String? // 'dismissable' | 'untildays' | 'permanent'
  requestId   String?

  account Account  @relation(fields: [accountId], references: [id])
  request Request? @relation(fields: [requestId], references: [id])

  @@map("notifications")
}

model Request {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  action      String // 'family_invitation' | 'access_invitation' | 'display_name_request'
  type        String? // 'partner' | 'dependent' | 'other'
  data        Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender        Account        @relation("SentRequests", fields: [senderId], references: [id])
  recipient     Account        @relation("ReceivedRequests", fields: [recipientId], references: [id])
  notifications Notification[]

  @@map("requests")
}

model Family {
  id        String   @id @default(uuid())
  createdBy String
  memberIds String[]
  members   Json // Array of { accountId: string, addedOn: DateTime, addedBy: string, hidden: boolean, status: string }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("families")
}

model BackupCode {
  id        String   @id @default(uuid())
  accountId String
  code      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@map("backup_codes")
}

model Verification {
  id               String    @id @default(uuid())
  accountId        String
  type             String // 'email' | 'phone' | 'identity' | 'account'
  token            String?
  code             String?
  status           String    @default("pending") // 'pending' | 'verified' | 'expired' | 'approved' | 'revoked'
  reason           String?
  category         String?
  verifiedBy       String?
  revokedBy        String?
  revocationReason String?
  createdAt        DateTime  @default(now())
  verifiedAt       DateTime?
  revokedAt        DateTime?

  account Account @relation(fields: [accountId], references: [id])

  @@map("verifications")
}

model Contact {
  id          String @id @default(uuid())
  accountId   String
  contactType String
  value       String

  account Account @relation(fields: [accountId], references: [id])

  @@map("contacts")
}

model NeupId {
  id        String  @id // The neupId string itself
  accountId String
  isPrimary Boolean @default(false)

  account Account @relation(fields: [accountId], references: [id])

  @@map("neup_ids")
}

model Password {
  accountId           String   @id
  hash                String
  passwordLastChanged DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@map("passwords")
}

model Permit {
  id               String    @id @default(uuid())
  permitType       String? // e.g. "property", "vehicle", "business"
  permitSubType    String? // e.g. "residential", "commercial"
  permitNumber     String?
  issuingAuthority String?
  issueDate        DateTime?
  expiryDate       DateTime?
  status           String    @default("active") // active, expired, revoked
  accountId        String
  targetAccountId  String?
  forSelf          Boolean   @default(false)
  isRoot           Boolean   @default(false)
  fullAccess       Boolean   @default(false)
  permissions      String[]
  restrictions     String[]
  createdOn        DateTime  @default(now())
  managedBy        String?

  account       Account  @relation(fields: [accountId], references: [id])
  targetAccount Account? @relation("TargetAccount", fields: [targetAccountId], references: [id])

  @@map("permits")
}

model Session {
  id             String    @id @default(uuid())
  accountId      String
  ipAddress      String
  userAgent      String
  lastLoggedIn   DateTime
  loginType      String
  geolocation    String?
  deviceType     String? // 'android' | 'ios' | 'web' | etc.
  expiresOn      DateTime?
  isExpired      Boolean   @default(false)
  authSessionKey String?
  dependentKeys  Json?

  appSessions AppSession[]
  account     Account      @relation(fields: [accountId], references: [id])

  @@map("sessions")
}

// New models for error tracking and bug reports
model ErrorLog {
  id           String   @id @default(uuid())
  type         String // 'ai' | 'database' | 'validation' | 'auth' | 'unknown'
  context      String
  message      String
  status       String   @default("new") // 'new' | 'in_progress' | 'solved'
  accountId    String?
  ipAddress    String?
  geolocation  String?
  reproSteps   String?
  solution     String?
  solvedBy     String?
  problemLevel String? // 'hot' | 'warm' | 'cold'
  timestamp    DateTime @default(now())

  account Account? @relation(fields: [accountId], references: [id])

  @@map("error_logs")
}

model BugReport {
  id         String   @id @default(uuid())
  reportType String   @default("submitted")
  context    String // title
  message    String // description
  status     String   @default("new") // 'new' | 'in_progress' | 'solved'
  reportedBy String?
  timestamp  DateTime @default(now())

  @@map("bug_reports")
}

model Application {
  id             String   @id
  name           String
  status         String   @default("development")
  party          String   @default("third") // 'first' | 'third'
  description    String?
  icon           String?
  website        String?
  developer      String?
  appSecret      String?
  access         Json?
  policies       Json?
  endpoints      Json?
  ownerAccountId String?
  createdAt      DateTime @default(now())

  owner               Account?                  @relation(fields: [ownerAccountId], references: [id])
  connections         UserAppConnection[]
  appAuthentications  AppAuthentication[]
  appSessions         AppSession[]
  externalSessions    AuthSessionExternal[]
  externalRoles       AuthRoleExternal[]
  externalPermissions AuthPermissionsExternal[]

  // New Auth Team & Permission Models
  authTeams                AuthTeam[]
  authTeamsExternal        AuthTeamExternal[]
  authRoles                AuthRole[]
  authPermissionRecipients AuthPermissionRecipient[]

  @@map("applications")
}

model AuthTeam {
  id          String   @id @default(uuid())
  appId       String
  accountId   String // Admin/Manager account
  recipientId String // User being added
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())

  application Application @relation(fields: [appId], references: [id])
  account     Account     @relation("AccountAsAdmin", fields: [accountId], references: [id])
  recipient   Account     @relation("AccountAsTeamMember", fields: [recipientId], references: [id])

  @@unique([appId, accountId, recipientId])
  @@map("auth_teams")
}

model AssetGroupInfo {
  id      String  @id @default(uuid())
  name    String
  details String?

  members AssetGroupMember[]
  assets  Asset[]

  @@map("assetGroupInfo")
}

model AssetGroupMember {
  id            String    @id @default(uuid())
  assetGroup    String
  member        String
  isPermanent   Boolean   @default(false)
  validTill     DateTime?
  hasFullPermit Boolean   @default(false)

  assetGroupInfo AssetGroupInfo    @relation(fields: [assetGroup], references: [id], onDelete: Cascade)
  roles          AssetMemberRole[]

  @@unique([assetGroup, member])
  @@index([assetGroup])
  @@map("assetGroupMember")
}

model Asset {
  id         String  @id @default(uuid())
  asset      String
  type       String
  assetGroup String
  details    String?

  assetGroupInfo AssetGroupInfo    @relation(fields: [assetGroup], references: [id], onDelete: Cascade)
  roles          AssetMemberRole[] @relation("AssetToMemberRoles")

  @@index([assetGroup])
  @@map("asset")
}

model AssetMemberRole {
  id          String @id @default(uuid())
  assetMember String
  asset       String
  role        String

  member   AssetGroupMember @relation(fields: [assetMember], references: [id], onDelete: Cascade)
  assetRef Asset            @relation("AssetToMemberRoles", fields: [asset], references: [id], onDelete: Cascade)

  @@unique([assetMember, asset])
  @@index([assetMember])
  @@index([asset])
  @@map("assetMemberRole")
}

model AuthTeamExternal {
  id          String   @id @default(uuid())
  appId       String
  accountId   String // Admin/Manager account
  recipientId String // User being added
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())

  application Application @relation(fields: [appId], references: [id])
  account     Account     @relation("AccountAsExternalAdmin", fields: [accountId], references: [id])
  recipient   Account     @relation("AccountAsExternalTeamMember", fields: [recipientId], references: [id])

  @@unique([appId, accountId, recipientId])
  @@map("auth_teams_external")
}

model AuthRole {
  id          String   @id @default(uuid())
  appId       String
  accountId   String
  role        String
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())

  application Application @relation(fields: [appId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])

  @@unique([appId, accountId])
  @@map("auth_roles")
}

model AuthPermissionRecipient {
  id          String    @id @default(uuid())
  appId       String
  recipientId String
  ownerId     String
  assetId     String? // Optional asset identifier
  permission  String
  isPermanent Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  application Application @relation(fields: [appId], references: [id])
  recipient   Account     @relation("RecipientPermissions", fields: [recipientId], references: [id])
  owner       Account     @relation("OwnerPermissions", fields: [ownerId], references: [id])

  @@map("auth_permission_recipients")
}

model UserAppConnection {
  id          String   @id @default(uuid())
  accountId   String
  appId       String
  connectedAt DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("user_app_connections")
}

model AppAuthentication {
  id          String   @id @default(uuid())
  appId       String
  accountId   String
  permissions Json?    @default("[]")
  createdAt   DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([appId, accountId])
  @@map("app_authentications")
}

model AppSession {
  id           String   @id @default(uuid())
  accountId    String
  sessionId    String // Link to NeupAccount session
  appId        String
  sessionValue String   @unique // The specific session token for the app
  createdOn    DateTime @default(now())
  activeTill   DateTime

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("app_sessions")
}

model AuthSessionExternal {
  id         String   @id @default(uuid())
  accountId  String
  appId      String
  sessionId  String
  sessionKey String
  jwt        String   @db.Text
  expiresOn  DateTime
  createdAt  DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@map("auth_sessions_external")
}

model AuthRoleExternal {
  id        String   @id @default(uuid())
  accountId String
  appId     String
  role      String
  hasExtra  Boolean  @default(false)
  createdAt DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("auth_roles_external")
}

model AuthPermissionsExternal {
  id          String   @id @default(uuid())
  accountId   String
  appId       String
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())

  account     Account     @relation(fields: [accountId], references: [id])
  application Application @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
  @@map("auth_permissions_external")
}
