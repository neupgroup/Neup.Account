# Firebase Project Configuration
# These variables are needed for the client-side Firebase SDK to connect to your project.
# You can find these values in your Firebase project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Genkit (Google AI) Configuration
# This is required for the AI features powered by the Gemini model.
# You can generate a new API key from Google AI Studio.
GEMINI_API_KEY=""

# TOTP Encryption key.
# This is used to encrypt the TOTP.
TOTP_ENCRYPTION_KEY=""
